{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "LLDB: CTest Runner",
      "type": "lldb",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopOnEntry": false
    },
    {
      "name": "Debug Catch2 Tests",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/microgpt_tests",
      "args": [
        // Optional: You can isolate a specific test by passing its name here
        // "Model tests"
      ],
      "cwd": "${workspaceFolder}",
      "stopOnEntry": false
    }
  ]
}